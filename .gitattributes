# Normalize line endings on checkout
* text=auto

# ── Scripts ──────────────────────────────────────────────────────────────────
*.sh   text eol=lf
*.bash text eol=lf

# ── Backend (Python / Alembic) ───────────────────────────────────────────────
*.py   text eol=lf
*.pyi  text eol=lf
*.cfg  text eol=lf
*.ini  text eol=lf
*.toml text eol=lf
*.mako text eol=lf

# ── Frontend (React / Vite / Tailwind) ───────────────────────────────────────
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf

# ── Mobile (Expo / React Native / Android) ───────────────────────────────────
*.kt         text eol=lf
*.java       text eol=lf
*.gradle     text eol=lf
*.properties text eol=lf
*.xml        text eol=lf
gradlew      text eol=lf
gradlew.bat  text eol=crlf

# ── Config / data formats ────────────────────────────────────────────────────
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.env  text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.sql  text eol=lf

# ── Binary — never diff or mangle ────────────────────────────────────────────
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.svg        binary
*.webp       binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.otf        binary
*.eot        binary
*.jar        binary
*.apk        binary
*.aab        binary
*.ipa        binary
*.jks        binary
*.p12        binary
*.keystore   binary
*.zip        binary
*.gz         binary
*.tar        binary
