# Database (PostgreSQL DSN format)
# Use host=postgres when running via docker-compose; host=localhost for local dev
DATABASE_URL=host=117.55.227.238 port=5432 user=connectors_user password=7cH7F_9Mf7£j dbname=connectors_db sslmode=disable TimeZone=UTC

# Redis
# Use redis://redis:6379 when running via docker-compose; redis://localhost:6379 for local dev
REDIS_URL=redis://localhost:6379

# JWT secret (min 32 chars)
SECRET_KEY=V6TP3uXntfM6RlQO82laWVPcUF7-d1a_-HSfy9YgjoZiGg22rK0z0HfQQyoRJ58i


# Only allow registration from this domain
COMPANY_EMAIL_DOMAIN=compunetconnections.com,compunet.work

# File uploads
MAX_FILE_SIZE_MB=10
UPLOADS_DIR=./uploads

# AWS S3 (optional — leave blank to use local storage)
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── WebRTC SFU (audio/video calls) ──────────────────────────────────────────
# Calls run over native WebRTC against the backend's built-in Pion SFU. The
# browser fetches its STUN/TURN servers from GET /api/calls/ice-servers.

# STUN servers advertised to the browser (comma-separated).
STUN_URLS=stun:stun.l.google.com:19302

# TURN relay (coturn) — the fallback when a direct browser↔SFU path fails.
# TURN_SECRET MUST equal static-auth-secret in coturn/turnserver.conf.
# Leave TURN_URL blank to disable TURN (STUN-only). Comma-separate multiple URLs.
# Example: turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
TURN_URL=turn:<YOUR_PUBLIC_IP>:3478?transport=udp,turn:<YOUR_PUBLIC_IP>:3478?transport=tcp
TURN_SECRET=<strong_random_secret_min_32_chars — must match coturn/turnserver.conf>
TURN_REALM=orgchat

# SFU media binding. WEBRTC_UDP_PORT is the single UDP port the SFU listens on
# (publish it in docker-compose). WEBRTC_NAT_1TO1_IP is the host IP the SFU
# advertises as its ICE host candidate — set to your host's LAN IP when running
# in Docker; leave blank when running the backend directly on the host.
WEBRTC_UDP_PORT=50000
WEBRTC_NAT_1TO1_IP=

# ── Google Calendar OAuth2 ───────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Add http://localhost:8000/api/google/calendar/callback as an authorised redirect URI
GOOGLE_CLIENT_ID=<from Google Cloud Console>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>
GOOGLE_REDIRECT_URL=http://localhost:8000/api/google/calendar/callback

# URL of the frontend — used to redirect the browser after OAuth callback
FRONTEND_URL=http://localhost:5173
