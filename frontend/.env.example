# Backend URLs — for local dev point to localhost, for Docker use service names
VITE_BACKEND_URL=http://localhost:8000
VITE_BACKEND_WS_URL=ws://localhost:8000

# Audio/video calls run over native WebRTC against the backend's built-in SFU.
# The browser gets its STUN/TURN servers from GET /api/calls/ice-servers, so
# there is no call-server config here — see backend-go/.env for STUN/TURN.
